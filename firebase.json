{
  "hosting": {
    "public": ".",
    "headers": [
      {
        "source": "**/*.@(html|css|js)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      }
    ],
    "ignore": [
      "firebase.json",
      ".firebaserc",
      ".firebase/**",
      ".git/**",
      "**/.*",
      "**/.firebase/**",
      "**/.git/**",
      "**/node_modules/**"
    ]
  }
}

